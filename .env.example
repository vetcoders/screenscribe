# Screenscribe configuration — copy to ~/.config/screenscribe/config.env
# or export these as environment variables. Never commit real keys.

# ── API key (required) — first non-empty wins ───────────────────────────────
SCREENSCRIBE_API_KEY=
# OPENAI_API_KEY=
# LIBRAXIS_API_KEY=

# ── Endpoints (OpenAI-compatible; defaults target the LibraxisAI provider) ──
SCREENSCRIBE_STT_ENDPOINT=https://api.libraxis.cloud/v1/audio/transcriptions
SCREENSCRIBE_LLM_ENDPOINT=https://api.libraxis.cloud/v1/responses
SCREENSCRIBE_VISION_ENDPOINT=https://api.libraxis.cloud/v1/responses
# Alternative: a single base URL that auto-derives the /v1/... endpoints
# SCREENSCRIBE_API_BASE=https://api.openai.com

# ── Models ──────────────────────────────────────────────────────────────────
SCREENSCRIBE_STT_MODEL=whisper-1
SCREENSCRIBE_LLM_MODEL=programmer
SCREENSCRIBE_VISION_MODEL=programmer

# ── Language / processing ───────────────────────────────────────────────────
SCREENSCRIBE_LANGUAGE=en
SCREENSCRIBE_VISION=true
# Semantic LLM-merge pass dedups cross-category paraphrases after the cheap
# heuristic dedup. On by default; set to a falsey value (false/0/no) to fall
# back to heuristic-only dedup. A missing LLM API key also makes it a no-op.
SCREENSCRIBE_LLM_MERGE=true

# ── Optional STT fallback (opt-in: tried only if the primary STT endpoint fails) ──
# Routes your audio to a second provider on fallback, so it is off by default.
# SCREENSCRIBE_STT_FALLBACK_ENDPOINT=https://api.openai.com/v1/audio/transcriptions
# SCREENSCRIBE_STT_FALLBACK_API_KEY=
# SCREENSCRIBE_STT_FALLBACK_MODEL=whisper-1
